{
  "expo": {
    "name": "sage",
    "slug": "sage",
    "version": "10.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rafaelperazzo.appdc"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.rafaelperazzo.appdc",
      "versionCode": 9
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "sage",
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bb4a9eba-9c40-49d1-a03a-fada08228e32"
      }
    },
    "owner": "rafaelperazzo"
  }
}
